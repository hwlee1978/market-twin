{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/lib/simulation/*": ["./packages/shared/src/simulation/*"],
      "@/lib/llm": ["./packages/shared/src/llm/index"],
      "@/lib/llm/*": ["./packages/shared/src/llm/*"],
      "@/lib/reference": ["./packages/shared/src/reference/index"],
      "@/lib/reference/*": ["./packages/shared/src/reference/*"],
      "@/lib/decision-aid/*": ["./packages/shared/src/decision-aid/*"],
      "@/lib/market-research/*": ["./packages/shared/src/market-research/*"],
      "@/lib/quality/*": ["./packages/shared/src/quality/*"],
      "@/lib/format/*": ["./packages/shared/src/format/*"],
      "@/lib/countries": ["./packages/shared/src/countries"],
      "@/lib/supabase/admin": ["./packages/shared/src/supabase/admin"],
      "@/lib/email/*": ["./packages/shared/src/email/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
