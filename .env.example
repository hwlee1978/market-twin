# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM providers (set at least one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Default provider/model used by every stage of the simulation engine.
# provider: anthropic | openai | gemini
LLM_DEFAULT_PROVIDER=anthropic
LLM_DEFAULT_MODEL=claude-sonnet-4-6

# Optional per-stage overrides — leave blank to inherit LLM_DEFAULT_*.
# Useful for cost control: cheap+fast model for high-volume persona batches,
# stronger model only for the executive synthesis. Stages: personas, countries,
# pricing, synthesis.
#
# Recommended cost-optimized config (≈50% cheaper, similar quality):
#   LLM_PERSONAS_PROVIDER=anthropic
#   LLM_PERSONAS_MODEL=claude-haiku-4-5
#   LLM_SYNTHESIS_PROVIDER=anthropic
#   LLM_SYNTHESIS_MODEL=claude-sonnet-4-6
LLM_PERSONAS_PROVIDER=
LLM_PERSONAS_MODEL=
LLM_COUNTRIES_PROVIDER=
LLM_COUNTRIES_MODEL=
LLM_PRICING_PROVIDER=
LLM_PRICING_MODEL=
LLM_SYNTHESIS_PROVIDER=
LLM_SYNTHESIS_MODEL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostHog analytics (optional). Leave NEXT_PUBLIC_POSTHOG_KEY blank to
# disable — capture() calls become no-ops. When set, the provider still
# requires the user to accept the cookie banner before any events are
# sent. Host defaults to https://us.i.posthog.com.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
