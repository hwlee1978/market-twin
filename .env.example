# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM providers (set at least one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Default provider/model used by every stage of the simulation engine.
# provider: anthropic | openai | gemini
LLM_DEFAULT_PROVIDER=anthropic
LLM_DEFAULT_MODEL=claude-sonnet-4-6

# Per-stage model overrides — leave blank to inherit LLM_DEFAULT_*.
#
# Voice-safe cost optimisation:
#   - Personas: keep Sonnet — generates 1인칭 voice quotes that are a key
#     product differentiator. Haiku tends to flatten voice into less-nuanced
#     phrasing. NOT WORTH the savings here.
#   - Synthesis / Regulatory / Critique: keep Sonnet (LLM_DEFAULT_MODEL).
#     Vision, real-law accuracy, and consistency-checking matter.
#   - Countries / Pricing: pure structured JSON output (rankings, curves) with
#     no narrative or voice. Haiku 4.5 handles JSON formatting well at ~3x
#     speed and ~70% cheaper.
#
# RECOMMENDED config (≈10-15% cost reduction, voice-quality preserved):
#   LLM_COUNTRIES_PROVIDER=anthropic
#   LLM_COUNTRIES_MODEL=claude-haiku-4-5-20251001
#   LLM_PRICING_PROVIDER=anthropic
#   LLM_PRICING_MODEL=claude-haiku-4-5-20251001
#   # Personas + Synthesis stay on Sonnet — DO NOT override LLM_PERSONAS_MODEL
#   # unless you've verified voice quality stays acceptable for your locale.
#
# AGGRESSIVE config (≈50-60% cost, but voice quality may drop):
#   ...also add LLM_PERSONAS_MODEL=claude-haiku-4-5-20251001
#   Run a side-by-side test sim and compare voice naturalness before committing.
LLM_PERSONAS_PROVIDER=
LLM_PERSONAS_MODEL=
LLM_COUNTRIES_PROVIDER=
LLM_COUNTRIES_MODEL=
LLM_PRICING_PROVIDER=
LLM_PRICING_MODEL=
LLM_SYNTHESIS_PROVIDER=
LLM_SYNTHESIS_MODEL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostHog analytics (optional). Leave NEXT_PUBLIC_POSTHOG_KEY blank to
# disable — capture() calls become no-ops. When set, the provider still
# requires the user to accept the cookie banner before any events are
# sent. Host defaults to https://us.i.posthog.com.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Sentry error monitoring (optional). Both DSNs hit the same project —
# server uses SENTRY_DSN (not exposed to browser), client uses
# NEXT_PUBLIC_SENTRY_DSN (inlined into JS bundle). Leave blank to disable
# capture entirely. SENTRY_AUTH_TOKEN is only needed at build time to
# upload source maps so production stack traces resolve to original TS;
# local dev works without it.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ────────────────────────────────────────────────────────────────────
# Billing (Stripe + Toss). All optional until paid plans are activated.
# Leave blank for closed-beta / invite-only deployments.
# ────────────────────────────────────────────────────────────────────

# Stripe — global USD card billing.
# Get keys from https://dashboard.stripe.com → Developers → API keys.
# Use sk_test_… for staging, sk_live_… for production.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Per-plan / per-cycle Stripe price IDs.
# Setup: in Stripe dashboard create one Product per tier, then 2 prices
# per product (monthly + annual). Copy the price IDs (price_…) into the
# vars below. Keep the slug pattern STRIPE_PRICE_<PLAN>_<CYCLE>.
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_VALIDATOR_MONTHLY=
STRIPE_PRICE_VALIDATOR_ANNUAL=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_ANNUAL=

# Toss Payments — Korean KRW recurring (빌링키 flow).
# Get keys from https://developers.tosspayments.com (test_sk_… or live_sk_…).
# CLIENT_KEY is exposed to the browser (Toss SDK widget needs it).
TOSS_SECRET_KEY=
NEXT_PUBLIC_TOSS_CLIENT_KEY=

# Toss webhook HMAC secret. Configure in Toss merchant console:
#   Webhooks → URL: {APP_BASE_URL}/api/billing/toss/webhook
#   → copy the displayed secret here.
# Without this, /api/billing/toss/webhook fail-closes (returns 401 to
# Toss) — the renewal cron continues working as a fallback.
TOSS_WEBHOOK_SECRET=

# NICE Payments (포스타트 / V2 신모듈) — Toss를 대체할 KRW 정기결제 PG.
# 포스타트는 MID/MerchantKey 없이 client key + secret key만으로 연동한다.
# 키 발급: start.nicepay.co.kr 로그인 → 개발정보 > KEY정보 > +발급.
# NICE_API_BASE 미설정 시 운영계(api.nicepay.co.kr). 샌드박스는 아래로 설정.
NICE_CLIENT_ID=
NICE_SECRET_KEY=
# NICE_API_BASE=https://sandbox-api.nicepay.co.kr

# KRW 정기결제 PG 선택: 'toss'(기본) | 'nicepay'. NICE는 결제창 없이 자체
# 카드입력 폼으로 빌키를 발급하므로 브라우저 분기를 위해 public 노출.
# NICE는 계약 완료 + NICE 내부셋팅 후에만 실연동되니 그 전까진 toss로 둘 것.
NEXT_PUBLIC_KRW_PROVIDER=toss

# Cron auth. Required for all Vercel-scheduled endpoints under
# /api/admin/zombie-cleanup, /api/billing/toss/renew, /api/billing/
# trial-reminder, /api/mrai/*/cron, /api/mrai/seo/google/cron.
# Generate a random 32+ char string and set it in Vercel env.
CRON_SECRET=

# Super-admin emails (comma-separated). Members can access
# /admin/llm-usage, /admin/site-settings, and the app-settings PATCH
# endpoint.
SUPERADMIN_EMAILS=

# 기업마당 (bizinfo.go.kr) 지원사업정보 API 키.
# 1,385+ 정부 지원사업 공개 데이터 수집용 (챌린지 제공 데이터 도착 전
# 매칭 엔진 데모용). 발급: https://www.bizinfo.go.kr/apiDetail.do?id=bizinfoApi
# 사용: npm run fetch:bizinfo  (자동으로 ch_pp_programs/ch_voucher_programs 적재)
BIZINFO_API_KEY=

# Challenge (2026 AI+ OpenData) demo sandbox workspace UUID. 비인증
# 사용자가 /sme-strategy 페이지의 추천·콘텐츠·영상 endpoint를 호출하면
# 이 workspace에 기록됨. 응모/심사위원이 가입 없이 평가 가능하도록.
# 1) Mr.AI에서 workspace 하나 생성 → UUID 복사 (예: SQL: SELECT id,
#    name FROM workspaces WHERE name LIKE '%demo%')
# 2) 아래 env에 설정
# 3) 인증 사용자는 본인 workspace 사용, 비인증은 demo로 fallback
# 미설정 시 비인증 호출은 401 unauthorized 반환.
CHALLENGE_DEMO_WORKSPACE_ID=

# ────────────────────────────────────────────────────────────────────
# Open beta (Market Twin 시뮬레이션 무료 베타)
# ────────────────────────────────────────────────────────────────────

# 셀프서비스 회원가입 개방.
# ★실사용 권장 경로: /admin/site-settings 의 "회원가입 공개" 토글
#   (런타임·즉시 반영, 재배포 불필요). 이메일·비번 가입과 구글 OAuth
#   가입을 모두 이 토글 하나로 제어.
# 이 env는 DB app_settings.signup_enabled row가 "아직 없을 때"만 쓰이는
# fallback. 토글을 한 번이라도 저장하면 DB 값이 우선이라 이 env는 무시됨.
NEXT_PUBLIC_SIGNUP_ENABLED=true

# Mr.AI(마케팅 자동화) 탭. 이번 베타는 시뮬레이션만 공개하므로 false 유지.
# true로 켜면 /mr-ai/* 라우트와 메뉴가 노출됨.
NEXT_PUBLIC_MRAI_ENABLED=false

# 무료 베타 사용량. 미설정 시 코드 기본값(1회 / 7일).
# 신규 가입 워크스페이스에 부여되는 무료(hypothesis = 초기 검증 티어)
# 시뮬레이션 횟수와 체험 기간. hypothesis 티어만 열려 있어 1회당 실비
# ~$3-5, 1인당 총비용은 대략 BETA_TRIAL_SIMS × $3-5 로 상한이 잡힘.
# 베타 설정: 초기 검증 2회 / 1주일.
# (BETA_TRIAL_DAYS=7 은 코드 기본값과 동일 → 생략 가능. 실제로 바꿔야
#  하는 값은 BETA_TRIAL_SIMS=2 뿐.)
BETA_TRIAL_SIMS=2
BETA_TRIAL_DAYS=7

# trial 남용 차단 한도 상향. 기본값(도메인 5 / IP 3, 24h)은 액셀러레이터·
# 대학·사내 공유망에서 정상 베타 테스터까지 막을 수 있어 베타 기간엔 상향.
TRIAL_ABUSE_DOMAIN_24H_MAX=50
TRIAL_ABUSE_IP_24H_MAX=20
