{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "src/app/api/simulations/[id]/run/route.ts": { "maxDuration": 800 },
    "src/app/api/simulations/[id]/retry/route.ts": { "maxDuration": 800 },
    "src/app/api/admin/simulations/[id]/retry/route.ts": { "maxDuration": 800 },
    "src/app/api/projects/demo/route.ts": { "maxDuration": 800 }
  },
  "crons": [
    {
      "path": "/api/billing/toss/renew",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/billing/trial-reminder",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/admin/zombie-cleanup",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/mrai/briefings/cron",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/mrai/publications/cron",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/mrai/crawl/cron",
      "schedule": "30 17 * * *"
    },
    {
      "path": "/api/mrai/content-drafts/auto-publish-cron",
      "schedule": "*/10 * * * *"
    }
  ]
}
